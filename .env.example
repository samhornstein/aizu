# Reference for all Aizu settings — copy what you need into .env.
# Required: GITHUB_TOKEN and AIZU_REPOS. A model credential is only needed
# when no local model server is running on a standard port (see below).

# --- Required ---

# GitHub personal access token (PAT) with `repo` scope — your own account
# works fine. Classic: https://github.com/settings/tokens
# Optional: use a token from a dedicated bot account instead if you want
# Aizu's replies attributed to a separate identity.
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# Repositories to watch, comma-separated: owner1/repo1,owner2/repo2
AIZU_REPOS=owner/repo

# Model credential. A local server (Ollama, llama.cpp, LM Studio) on its
# standard port is auto-detected — nothing to set. Otherwise set one of:
#   Local/remote OpenAI-compatible server on a non-standard port or host:
# OPENAI_BASE_URL=http://host.docker.internal:8080/v1
#   API key for a hosted model (e.g. Anthropic, OpenAI):
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# OPENAI_API_KEY=sk-YOUR_KEY_HERE

# --- Optional (defaults shown) ---
# AIZU_ENGINE=pi                             # coding agent preset: pi | claude (claude needs ANTHROPIC_API_KEY)
# AIZU_TRIGGER=aizu                          # must begin the comment/issue text
# AIZU_USERS=alice,bob                       # exactly these logins may trigger (overrides the write-access default)
# AIZU_ALLOW_ALL=true                        # DANGER: let anyone who can comment trigger the agent
# CONTAINER_IMAGE=ghcr.io/samhornstein/aizu-agent-pi:latest  # override the preset's sandbox image
# ENGINE_COMMAND=pi -p "$(cat {prompt_file})" # override the preset's command ({prompt_file} and {model} are substituted)
# AIZU_TIMEOUT=3600                           # agent run timeout, seconds
# AIZU_MAX_RUNS_PER_HOUR=10                   # per-repo cap on agent runs; 0 disables
# AIZU_CONCURRENCY=1                          # agent tasks run in parallel; each uses up to 4g RAM / 2 CPUs
# POLL_INTERVAL=15                           # seconds between GitHub polls
# REDIS_URL=redis://redis:6379               # defaults to the bundled Redis; set to a hosted URL to override
