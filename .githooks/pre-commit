#!/bin/sh
set -e

# Ensure all Go files are formatted.
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
    echo "error: the following files need formatting (run: gofmt -w .):"
    printf '%s\n' "$unformatted"
    exit 1
fi

# Lint (mirrors the CI lint step; CI pins the version — see
# .github/workflows/ci.yml — keep the local install roughly in sync).
if ! command -v golangci-lint > /dev/null 2>&1; then
    echo "error: golangci-lint not found (install: https://golangci-lint.run/welcome/install/)"
    exit 1
fi
golangci-lint run

# Run unit tests (skip e2e tests which require external services).
# -race matches CI so local green means CI green.
go test -race ./...
