# --- Authentication (choose one) ---

# Option A: GitHub App (recommended)
# See docs for setup instructions.
# GITHUB_APP_ID=12345678
# GITHUB_APP_INSTALLATION_ID=87654321
# GITHUB_APP_KEY="-----BEGIN EC PRIVATE KEY-----\nMIGHAgEAM...\n-----END EC PRIVATE KEY-----"

# Option B: Personal Access Token (PAT) with repo scope.
# Classic: https://github.com/settings/tokens (select the `repo` scope)
# GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# --- Model credentials (set whichever your model needs) ---

# API key (Anthropic or OpenAI):
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# OPENAI_API_KEY=sk-YOUR_KEY_HERE
# Local model server (e.g. llama.cpp):
# OPENAI_BASE_URL=http://host.docker.internal:8080/v1

# --- Optional overrides (defaults live in aizu.toml) ---
# REDIS_URL=redis://localhost:6379
# AIZU_TRIGGER=@aizu
# AIZU_REPOS=owner/repo1,owner/repo2
# AIZU_USERS=alice,bob
# CONTAINER_IMAGE=aizu-agent:pi
# ENGINE_COMMAND=pi -p "$(cat {prompt_file})"
# AIZU_TIMEOUT=600
# POLL_INTERVAL=30
