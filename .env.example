# GitHub personal access token (PAT) with repo scope.
# Classic: https://github.com/settings/tokens (select the `repo` scope)
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# Credentials passed through to the pi agent. Set whichever your model needs —
# an API key, a local model server, or both.
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# OPENAI_API_KEY=sk-YOUR_KEY_HERE
# MODEL_SERVER_HOST=host.docker.internal:8080

# --- Optional overrides (defaults live in aizu.toml) ---
# REDIS_URL=redis://localhost:6379
# AIZU_TRIGGER=@aizu
# AIZU_REPOS=owner/repo1,owner/repo2
# AIZU_USERS=alice,bob
# CONTAINER_IMAGE=aizu-agent:pi
# ENGINE_COMMAND=pi -p "$(cat {prompt_file})"
# AIZU_TIMEOUT=600
# POLL_INTERVAL=30
